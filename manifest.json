{
  "manifest_version": 3,
  "name": "UJAX Problem Collector",
  "version": "1.1.0",
  "description": "UJAX에서 문제 등록 시 백준 문제 데이터를 수집합니다",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://www.acmicpc.net/*",
    "https://solved.ac/*",
    "http://localhost:8080/*",
    "http://localhost:5173/*",
    "https://ujax.kro.kr/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.acmicpc.net/problem/*"],
      "js": ["scripts/content.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://www.acmicpc.net/status",
        "https://www.acmicpc.net/status?*"
      ],
      "js": ["scripts/statusContent.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://www.acmicpc.net/source/*"],
      "js": ["scripts/sourceContent.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://www.acmicpc.net/*"],
      "js": ["scripts/bojDetect.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "https://ujax.kro.kr/*"
      ],
      "js": ["scripts/ujaxBridge.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "UJAX Problem Collector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
